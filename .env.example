SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=sk-your-openai-key
FIRECRAWL_API_KEY=your-firecrawl-key
PRIMARY_LLM=gemini
SECONDARY_LLM=openai
PROJECT_ROOT_DIR=/Users/matthewbishop/BishopBot
REDIS_URL=redis://localhost:6379/0
TASK_QUEUE_NAME=bishopbot_tasks

# Gemini CLI
GEMINI_CLI_ARGS=--yolo

# Terminal session tuning
TERMINAL_BOOT_DELAY_SECONDS=7
TERMINAL_POLL_INTERVAL_SECONDS=40
TERMINAL_TAIL_LINES_WHATSAPP=40

# WhatsApp Cloud API (Meta)
WHATSAPP_ENABLED=false
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Optional: webhook signature verification
WHATSAPP_APP_SECRET=your-meta-app-secret
